{
  "version": 2,
  "buildCommand": "cd app && npm install --legacy-peer-deps && TURBOPACK=0 npm run build",
  "devCommand": "cd app && npm run dev",
  "installCommand": "cd app && npm install --legacy-peer-deps",
  "outputDirectory": "app/.next",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app/$1"
    }
  ]
}
